# Wake-on-LAN Configuration
# MAC_ADDRESS should be the MAC address of the device you want to wake up
# Format: XX:XX:XX:XX:XX:XX or XX-XX-XX-XX-XX-XX or XXXX.XXXX.XXXX or XXXXXXXXXXXX
MAC_ADDRESS=00:11:22:33:44:55

# Server port (optional, defaults to 8080)
PORT=8080

# Broadcast IP address (optional, defaults to 255.255.255.255)
# Use your network's broadcast address, e.g., 192.168.1.255
BROADCAST_IP=192.168.1.255

# Wake-on-LAN UDP port (optional, defaults to 9)
WOL_PORT=9
